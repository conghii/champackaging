generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                  String            @id @default(cuid())
  skuCode             String            @unique @map("sku_code")
  amazonAsin          String?           @map("amazon_asin")
  amazonFnsku         String?           @map("amazon_fnsku")
  productName         String            @map("product_name")
  category_id         String?
  category            ProductCategory?  @relation(fields: [category_id], references: [id])
  design_name         String?           @map("design_name")
  thumbnail_emoji     String?           @default("🎁") @map("thumbnail_emoji")
  sellingPrice        Decimal           @map("selling_price") @db.Decimal(10, 2)
  minStockFba         Int               @default(0) @map("min_stock_fba")
  leadTimeDays        Int               @default(0) @map("lead_time_days")
  status              ProductStatus     @default(ACTIVE)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  amazon_referral_pct Decimal           @default(15) @db.Decimal(5, 2)
  fba_fulfillment_fee Decimal           @default(0) @db.Decimal(10, 2)
  fba_storage_fee     Decimal           @default(0) @db.Decimal(10, 2)
  billOfMaterials     BillOfMaterial[]
  fbaInventory        FBAInventory?
  fbaShipmentItems    FBAShipmentItem[]
  salesData           SalesData[]
  workOrders          WorkOrder[]

  @@map("products")
}

model Material {
  id                 String              @id @default(cuid())
  materialCode       String              @unique @map("material_code")
  materialName       String              @map("material_name")
  category           String?
  unit               String
  currentStock       Decimal             @default(0) @map("current_stock") @db.Decimal(12, 3)
  minStock           Decimal             @default(0) @map("min_stock") @db.Decimal(12, 3)
  reorderQty         Decimal             @default(0) @map("reorder_qty") @db.Decimal(12, 3)
  avgUnitCost        Decimal             @default(0) @map("avg_unit_cost") @db.Decimal(10, 4)
  storageLocation    String?             @map("storage_location")
  createdAt          DateTime            @default(now()) @map("created_at")
  billOfMaterials    BillOfMaterial[]
  purchaseOrderItems PurchaseOrderItem[]
  bom_templates      BOMTemplate[]

  @@map("materials")
}

model BillOfMaterial {
  id              String   @id @default(cuid())
  productId       String   @map("product_id")
  materialId      String   @map("material_id")
  quantityPerUnit Decimal  @map("quantity_per_unit") @db.Decimal(10, 4)
  wastagePercent  Decimal  @default(0) @map("wastage_percent") @db.Decimal(5, 2)
  is_from_template Boolean @default(false)
  override_template Boolean @default(false)
  notes           String?
  material        Material @relation(fields: [materialId], references: [id])
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, materialId])
  @@map("bill_of_materials")
}

model Supplier {
  id             String          @id @default(cuid())
  supplierCode   String          @unique @map("supplier_code")
  supplierName   String          @map("supplier_name")
  country        String?
  contactPerson  String?         @map("contact_person")
  paymentTerms   String?         @map("payment_terms")
  currency       String          @default("USD")
  leadTimeDays   Int             @default(0) @map("lead_time_days")
  rating         Decimal?        @db.Decimal(2, 1)
  createdAt      DateTime        @default(now()) @map("created_at")
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  poNumber         String              @unique @map("po_number")
  supplierId       String              @map("supplier_id")
  status           POStatus            @default(DRAFT)
  currency         String              @default("USD")
  totalAmount      Decimal             @default(0) @map("total_amount") @db.Decimal(12, 2)
  paymentStatus    PaymentStatus       @default(UNPAID) @map("payment_status")
  expectedDelivery DateTime?           @map("expected_delivery")
  actualDelivery   DateTime?           @map("actual_delivery")
  createdAt        DateTime            @default(now()) @map("created_at")
  items            PurchaseOrderItem[]
  supplier         Supplier            @relation(fields: [supplierId], references: [id])

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  poId             String        @map("po_id")
  materialId       String        @map("material_id")
  quantityOrdered  Decimal       @map("quantity_ordered") @db.Decimal(12, 3)
  quantityReceived Decimal       @default(0) @map("quantity_received") @db.Decimal(12, 3)
  unitPrice        Decimal       @map("unit_price") @db.Decimal(10, 4)
  material         Material      @relation(fields: [materialId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

model WorkOrder {
  id                String    @id @default(cuid())
  woNumber          String    @unique @map("wo_number")
  productId         String    @map("product_id")
  quantityPlanned   Int       @map("quantity_planned")
  quantityCompleted Int       @default(0) @map("quantity_completed")
  quantityRejected  Int       @default(0) @map("quantity_rejected")
  status            WOStatus  @default(DRAFT)
  priority          Priority  @default(NORMAL)
  plannedStart      DateTime? @map("planned_start")
  plannedEnd        DateTime? @map("planned_end")
  actualStart       DateTime? @map("actual_start")
  actualEnd         DateTime? @map("actual_end")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  product           Product   @relation(fields: [productId], references: [id])

  @@map("work_orders")
}

model Employee {
  id           String         @id @default(cuid())
  employeeCode String         @unique @map("employee_code")
  fullName     String         @map("full_name")
  role         EmployeeRole   @default(PRODUCTION)
  salaryType   SalaryType     @default(MONTHLY) @map("salary_type")
  baseSalary   Decimal        @default(0) @map("base_salary") @db.Decimal(12, 2)
  hireDate     DateTime       @map("hire_date")
  status       EmployeeStatus @default(ACTIVE)

  @@map("employees")
}

model FBAShipment {
  id             String            @id @default(cuid())
  shipmentName   String            @map("shipment_name")
  status         FBAShipmentStatus @default(PLANNING)
  destinationFc  String?           @map("destination_fc")
  totalUnits     Int               @default(0) @map("total_units")
  shipDate       DateTime?         @map("ship_date")
  shippingCost   Decimal           @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  createdAt      DateTime          @default(now()) @map("created_at")
  trackingNumber String?           @map("tracking_number")
  items          FBAShipmentItem[]

  @@map("fba_shipments")
}

model FBAShipmentItem {
  id         String      @id @default(cuid())
  shipmentId String      @map("shipment_id")
  productId  String      @map("product_id")
  quantity   Int         @map("quantity")
  notes      String?
  product    Product     @relation(fields: [productId], references: [id])
  shipment   FBAShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("fba_shipment_items")
}

model FBAInventory {
  id             String   @id @default(cuid())
  productId      String   @unique @map("product_id")
  fulfillableQty Int      @default(0) @map("fulfillable_qty")
  inboundQty     Int      @default(0) @map("inbound_qty")
  reservedQty    Int      @default(0) @map("reserved_qty")
  updatedDate    DateTime @default(now()) @map("updated_date")
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("fba_inventory")
}

model SalesData {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  saleDate  DateTime @map("sale_date")
  unitsSold Int      @default(0) @map("units_sold")
  revenue   Decimal  @default(0) @db.Decimal(10, 2)
  returns   Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, saleDate])
  @@map("sales_data")
}

model users {
  id         String   @id
  email      String   @unique
  password   String
  name       String
  role       String   @default("warehouse")
  created_at DateTime @default(now())
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum POStatus {
  DRAFT
  SENT
  CONFIRMED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  DEPOSIT_PAID
  PARTIALLY_PAID
  FULLY_PAID
  OVERDUE
}

enum WOStatus {
  DRAFT
  PENDING
  IN_PROGRESS
  PAUSED
  QC_CHECK
  PACKAGING
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EmployeeRole {
  ADMIN
  PRODUCTION
  WAREHOUSE
  ACCOUNTING
}

enum SalaryType {
  MONTHLY
  HOURLY
  PER_UNIT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum FBAShipmentStatus {
  PLANNING
  LABELING
  READY_TO_SHIP
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RECEIVING
  LIVE
  CLOSED
}

model ProductCategory {
  id          String         @id @default(cuid())
  code        String         @unique  
  name        String    
  description String?
  color       String?   
  icon        String?   
  sort_order  Int            @default(0)
  products    Product[]
  bom_templates BOMTemplate[]
  created_at  DateTime       @default(now())

  @@map("product_categories")
}

model BOMTemplate {
  id              String          @id @default(cuid())
  category_id     String
  category        ProductCategory @relation(fields:[category_id], references:[id])
  material_id     String
  material        Material        @relation(fields:[material_id], references:[id])
  quantity_per_unit Decimal       @db.Decimal(10, 4)
  wastage_percent Decimal         @default(0) @db.Decimal(5, 2)
  notes           String?

  @@map("bom_templates")
}
